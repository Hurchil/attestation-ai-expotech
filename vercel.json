{
    "version": 2,
    "builds": [
      {
        "src": "api/**/*.js",
        "use": "@vercel/node"
      }
    ],
    "routes": [
      {
        "src": "/api/(.*)",
        "dest": "/api/server.js"
      }
    ],
    "env": {
      "MONGODB_URI": "@mongodb-uri",
      "JWT_SECRET": "@jwt-secret",
      "ADMIN_USERNAME": "@admin-username",
      "ADMIN_PASSWORD": "@admin-password"
    }
  }